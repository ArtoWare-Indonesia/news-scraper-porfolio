from scrapers.antara import AntaraScraper
from scrapers.tempo import TempoScraper


class ScraperManager:
    """Menjalankan semua scraper."""

    def __init__(self):
        self.scrapers = [
            AntaraScraper(),
            TempoScraper(),
        ]

    def run(self):
        all_articles = []

        for scraper in self.scrapers:

            scraper.logger.info(
                f"Running {scraper.__class__.__name__}"
            )

            try:
                articles = scraper.scrape()

                scraper.logger.info(
                    f"Collected {len(articles)} articles"
                )

                all_articles.extend(articles)

            except Exception as exc:

                scraper.logger.exception(
                    f"Failed: {exc}"
                )

        return all_articles
